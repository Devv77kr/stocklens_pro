rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — own data only
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Simple watchlist (ticker list)
    match /watchlists/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ML-prediction alert logs
    match /alerts/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Price alerts (wishlist) — full sub-collection access
    match /price_alerts/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Alert history — full sub-collection access
    match /alert_history/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
